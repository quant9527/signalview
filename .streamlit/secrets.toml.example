# 复制本文件为 secrets.toml 并填入真实配置（secrets.toml 已被 .gitignore 忽略，不会提交）
# Copy this file to secrets.toml and fill in your values.

[auth]
password = "your_login_password"

[connections.quantdb]
url = "postgresql://user:password@host:5432/dbname"

# Flight K 线 gRPC（K 线页、data.py 最新价等；也可用环境变量 FLIGHT_URL 覆盖未写 secrets 时的默认）
FLIGHT_URL = "grpc://127.0.0.1:50001"
