# 复制为 `.env` 后按需填写（勿提交含真实密码的 `.env`）
# signalml-train 会从当前目录向上查找 `.env`；也可用 SIGNALML_ENV_FILE 或 `train --env-file`

# ---------- 数据库（至少配置其一）----------
DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/quant


# 或使用 Streamlit 同款 secrets 文件路径（与 URL 二选一即可）
# SIGNALML_SECRETS=/path/to/signalview/.streamlit/secrets.toml

# ---------- 训练输出与窗口 ----------
SIGNALML_OUT=./artifacts/run1
SIGNALML_DAYS=180
SIGNALML_HORIZON=5
SIGNALML_CACHE=.cache/signalml

# 仅训练 exchange=as 的信号；留空表示不过滤（需在命令行用 --exchange ""）
SIGNALML_EXCHANGE=as
SIGNALML_TEST_RATIO=0.2

# ---------- 共振 ----------
SIGNALML_RESONANCE_DAYS=5
# SIGNALML_THS_SIGNAL_FILTER=
# SIGNALML_THS_POSITION=long

# 设为 1 / true / yes / on 即关闭对应特征（等价于命令行 --no-*）
# SIGNALML_NO_RESONANCE=
# SIGNALML_NO_THS_RESONANCE=
# SIGNALML_NO_KLINE_MARKET=

# ---------- K 线（与 flight_kline_client / README 一致）----------
FLIGHT_URL=grpc://127.0.0.1:50001
# SIGNALML_KLINE_SOURCE=flight_first

